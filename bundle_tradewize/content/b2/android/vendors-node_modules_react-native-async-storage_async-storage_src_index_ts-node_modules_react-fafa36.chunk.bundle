  .${y} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: inherit;
    background-color: var(--overlay-color);
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
  }

  a:hover > .${y}, button:hover > .${y} {
    opacity: var(--overlay-hover-opacity);
  }

  a:active > .${y}, button:active > .${y} {
